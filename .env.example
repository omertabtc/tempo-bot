# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_GUILD_ID=optional_guild_id_for_testing

# Tempo Blockchain Configuration
TEMPO_RPC_URL=https://rpc.tempo.xyz
TEMPO_EXPLORER_API=https://contracts.tempo.xyz/api
TEMPO_CHAIN_ID=42431

# Optional: Alternative explorers/RPCs
# TEMPO_EXPLORER_API=https://explore.tempo.xyz/api
# TEMPO_RPC_URL=https://your-private-rpc.com

# Analysis Settings
MAX_CONTRACT_SIZE=50000
ANALYSIS_TIMEOUT=60
ENABLE_BYTECODE_ANALYSIS=true

# Rate Limiting (per user)
RATE_LIMIT_WINDOW=60
RATE_LIMIT_MAX=3
